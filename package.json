{
    "name": "nodeboot",
    "version": "1.0.3",
    "description": "Node Boot makes it easy to create stand-alone, production-grade NodeJs based Applications that you can \"just run\". We take an opinionated view of the NodeJs platform and third-party libraries so you can get started with minimum fuss.",
    "author": "Manuel Santos <ney.br.santos@gmail.com>",
    "license": "MIT",
    "private": "true",
    "keywords": [
        "nodejs",
        "boot",
        "framework",
        "auto-configuration"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/nodejs-boot/node-boot.git"
    },
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=18",
        "pnpm": ">=7.5.1"
    },
    "main": "dist/index.js",
    "types": "src/index.ts",
    "scripts": {
        "build": "turbo run build",
        "build:clean": "turbo run clean:build",
        "dev": "turbo run dev",
        "lint-format": "turbo run --parallel lint format ",
        "lint-format:fix": "turbo run --parallel lint:fix format:fix",
        "lint": "eslint . --ext .js,.ts",
        "lint:fix": "eslint . --ext .js,.ts --fix",
        "test": "turbo run --parallel test",
        "tsc": "turbo run --parallel tsc",
        "tsc:full": "tsc --skipLibCheck false --incremental false",
        "memoryleak:detect": "timeout 30s node memory-leak-detector.js",
        "prepare": "husky install",
        "postinstall": "husky install",
        "prepack": "pinst --disable",
        "postpack": "pinst --enable",
        "format:check": "prettier --check '{packages,samples,servers,starters,tests}/**/{package.json,src/*.tsx,src/*.ts}'",
        "format:fix": "prettier --write '{packages,samples,servers,starters,tests}/**/{package.json,src/*.tsx,src/*.ts}'",
        "git:prune": "git fetch -p && for branch in $(git branch -vv | grep ': gone]' | awk '{print $1}'); do git branch -D $branch; done",
        "npm:prune": "pnpm store prune && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
        "changeset:create": "pnpm changeset",
        "release:version": "pnpm changeset version",
        "changeset:format": "pnpm prettier --write '{packages,samples,serverless,servers,starters}/*/{package.json,CHANGELOG.md}'",
        "release:status": "pnpm changeset status",
        "release:publish": "pnpm changeset publish",
        "nodeboot:update": "turbo run nodeboot:update",
        "nodeboot:check:type-deps": "node ./node_modules/@nodeboot/tools/dist/check-type-dependencies.js",
        "nodeboot:check:local-deps": "node ./node_modules/@nodeboot/tools/dist/verify-local-dependencies.js",
        "nodeboot:check:docs": "node ./node_modules/@nodeboot/tools/dist/check-docs-quality.js"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "pnpm tsc",
            "pnpm nodeboot:check:type-deps",
            "pnpm lint-format:fix"
        ],
        "*.{json,md,css,html}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@changesets/cli": "^2.28.1",
        "@nodeboot/tools": "^1.2.0",
        "@nodeboot/test": "^2.14.0",
        "@nodeboot/node-test": "^2.14.0",
        "@tsconfig/node-lts-strictest": "^18.12.1",
        "@types/memwatch-next": "^0.3.6",
        "@types/node": "^22.14.1",
        "@typescript-eslint/eslint-plugin": "^8.44.1",
        "@typescript-eslint/parser": "^8.44.1",
        "typescript-eslint": "^8.44.1",
        "eslint": "^10.0.0",
        "eslint-config-katxupa": "^1.0.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-import-x": "^4.5.0",
        "@eslint/js": "^10.0.0",
        "@eslint/eslintrc": "^3.2.0",
        "husky": "^8.0.0",
        "lint-staged": "^13.1.2",
        "nodemon": "^3.1.10",
        "memwatch-next": "^0.3.0",
        "pinst": "^3.0.0",
        "prettier": "^2.8.3",
        "prettier-plugin-organize-imports": "^3.2.4",
        "rimraf": "^5.0.5",
        "turbo": "^2.3.3",
        "typescript": "^5.9.2",
        "pactum": "^3.8.0",
        "testcontainers": "^11.7.2",
        "@testcontainers/toxiproxy": "^11.7.2",
        "node-test-reporter": "^1.2.0",
        "ts-node": "^10.9.2"
    },
    "packageManager": "pnpm@10.17.1"
}
